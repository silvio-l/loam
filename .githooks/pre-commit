#!/usr/bin/env bash
# loam.dev pre-commit: Struktur-Check der öffentlichen Docs (deterministisch, 0 Token).
# Die bewusste Push-Attestierung sitzt im pre-push-Hook, nicht hier.
# Aktivieren (einmalig pro Clone):  git config core.hooksPath .githooks
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"

# ── Riegel -1: ai-attribution-guard (mirror ~/.git-hooks/pre-commit) ─────────
# Kein KI-Agent darf als Autor/Committer/Contributor erscheinen. loam überschreibt
# core.hooksPath (-> .githooks) und shadowed damit den globalen Guard — daher hier.
_ident="$(git var GIT_AUTHOR_IDENT 2>/dev/null) $(git var GIT_COMMITTER_IDENT 2>/dev/null)"
if printf '%s' "$_ident" | grep -qiE 'anthropic|claude|copilot|cursor\.so|codeium|\[bot\]@'; then
  echo "╳ Commit blockiert — KI-Agent als Autor/Committer: $_ident" >&2
  echo "  → git config user.name/user.email auf deine Identität setzen." >&2
  exit 1
fi

# ── Riegel 0: interne, nicht-öffentliche Artefakte dürfen NIE getrackt werden ─
# Harte Denylist — greift auch bei `git add -f` (das nur .gitignore umgeht, nicht
# diesen Hook). Nur Additions/Modifications blocken, Deletions (Untracking) erlaubt.
DENY='^(CLAUDE\.md|CONTEXT\.md|docs/PRD\.md|docs/zielgruppe\.md|docs/public-docs-spec\.md|docs/readme-spec\.md|docs/adr/|\.wrangler/|\.readme-stamp$)'
blocked="$(git diff --cached --name-only --diff-filter=AM | grep -E "$DENY" || true)"
if [ -n "$blocked" ]; then
  cat >&2 <<EOF

╳ Commit blockiert — interne, nicht-öffentliche Artefakte gestaged:
$(printf '%s\n' "$blocked" | sed 's/^/    /')
  Diese Dateien gehören NICHT nach GitHub (lokal behalten, .gitignore'd).
  → 'git restore --staged <datei>' und nicht committen.
EOF
  exit 1
fi

QA="$ROOT/tool/docs-attest.sh"
[ -x "$QA" ] || { echo "pre-commit: $QA fehlt/nicht ausführbar"; exit 1; }
"$QA" check

# ── Nudge (nicht-blockierend, 0 Token): Zielgruppen-Eignung ──────────────────
# Kein Urteil, kein Gate (Eignung ist semantisch, nicht deterministisch prüfbar
# — ein LLM-Gate verstieße gegen Invariante 2 + Free-Tier-Disziplin und würde
# False Positives produzieren). Stattdessen: erinnern, den Lackmustest selbst
# anzulegen, wenn Produktfläche (CLI/Rules/Website) berührt wird.
SURFACE='^(packages/loam_cli/bin/|packages/loam_cli/lib/|web/)'
if git diff --cached --name-only --diff-filter=AM | grep -qE "$SURFACE"; then
  echo "› Produktfläche berührt — prüfe gegen docs/zielgruppe.md (Lackmustest):" >&2
  echo "  „Findet/hilft das echten Schaden, dem ein Entwickler blind vertraut?“" >&2
fi
