#!/usr/bin/env bash
# loam.dev pre-push: Public-Docs-Attestierungs-Schranke (deterministisch, 0 Token).
#
# Vor JEDEM Push muss die KI bewusst bestätigt haben, dass die README dem
# aktuellen Repo-Stand entspricht (Aufbau + Inhalt). Die einzige Art, die
# Schranke zu passieren, ist diese bewusste Bestätigung:
#
#     tool/docs-attest.sh attest      # nach echter Prüfung der README
#
# Aktivieren (einmalig pro Clone):  git config core.hooksPath .githooks
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
QA="$ROOT/tool/docs-attest.sh"
[ -x "$QA" ] || { echo "pre-push: $QA fehlt/nicht ausführbar"; exit 1; }

ZERO="0000000000000000000000000000000000000000"
attested="$("$QA" attested)"

block() {
  cat >&2 <<EOF

╳ Push blockiert — README nicht für diesen Stand attestiert.
  $1
  → README.md gegen den aktuellen Repo-Stand & docs/public-docs-spec.md PRÜFEN,
    dann BEWUSST bestätigen:   tool/docs-attest.sh attest
  Das ist die EINZIGE Art, die Schranke zu passieren (kein --no-verify).
EOF
  exit 1
}

# Struktur muss ohnehin stimmen.
"$QA" check >/dev/null || block "Struktur-Check (docs-attest.sh check) fehlgeschlagen."

# git liefert die Ref-Liste auf stdin — EINMAL puffern, beide Schleifen nutzen sie.
REFS="$(cat || true)"

# ── Riegel 1: kein KI-Co-Authored-By-Trailer darf je gepusht werden ──────────
# HARD RULE (CLAUDE.md). Zweiter Riegel zusätzlich zum commit-msg-Hook — fängt
# Commits, die den commit-msg-Hook umgangen haben (Merges, Cherry-Picks,
# --no-verify, Imports).
AI_TRAILER='^[Cc]o-[Aa]uthored-[Bb]y:.*(anthropic|copilot|claude|cursor|codeium)'
block_ai() {
  cat >&2 <<EOF

╳ Push blockiert — KI-Co-Authored-By-Trailer gefunden.
  $1
  → Trailer entfernen ('git rebase -i' + reword bzw. 'git commit --amend'),
    dann erneut pushen. (kein --no-verify)
EOF
  exit 1
}
while read -r _lref local_sha _rref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue
  # Annotierte Tags: git liefert die Tag-Objekt-SHA -> auf den Commit deref.
  local_sha="$(git rev-parse --verify --quiet "${local_sha}^{commit}" 2>/dev/null || echo "$local_sha")"
  if [ "${remote_sha:-$ZERO}" = "$ZERO" ]; then
    range="$(git rev-list "$local_sha" --not --remotes)"
  else
    range="$(git rev-list "${remote_sha}..${local_sha}")"
  fi
  [ -z "$range" ] && continue
  hit="$(git log --no-walk --format='%B' $range 2>/dev/null | grep -iE "$AI_TRAILER" || true)"
  [ -n "$hit" ] && block_ai "Treffer:
$hit"
done <<EOF
$REFS
EOF

# ── Riegel 1.5: keine Secrets/Tokens im Push (Content-Scan, Backstop) ─────────
# Fängt Secrets, die den pre-commit-Scan via --no-verify umgangen haben. Gleiche
# längen-qualifizierte Hochkonfidenz-Muster; Hunks der pattern-tragenden Guard-/
# Tool-Dateien werden übersprungen, damit die Detektor-Strings sich nicht selbst
# auslösen.
SECRET_RE='(sk-ant-[A-Za-z0-9_-]{24,}|gh[pousr]_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{40,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|AKIA[0-9A-Z]{16}|(ANTHROPIC_API_KEY|CLAUDE_CODE_OAUTH_TOKEN|GH_TOKEN|HOMEBREW_TAP_TOKEN|AWS_SECRET_ACCESS_KEY)[[:space:]]*[:=][[:space:]]*['\''"]?[A-Za-z0-9_/+.=-]{20,})'
block_secret() {
  cat >&2 <<EOF

╳ Push blockiert — mögliches Secret/Token in den zu pushenden Commits.
  $1
  → Secret aus der History entfernen (git rebase -i / git filter-repo), den
    Wert ROTIEREN, dann erneut pushen. (kein --no-verify)
EOF
  exit 1
}
while read -r _lref local_sha _rref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue
  local_sha="$(git rev-parse --verify --quiet "${local_sha}^{commit}" 2>/dev/null || echo "$local_sha")"
  if [ "${remote_sha:-$ZERO}" = "$ZERO" ]; then
    patch="$(git log -p --no-color "$local_sha" --not --remotes 2>/dev/null || true)"
  else
    patch="$(git log -p --no-color "${remote_sha}..${local_sha}" 2>/dev/null || true)"
  fi
  added="$(printf '%s\n' "$patch" | awk '
    /^diff --git / { skip = ($0 ~ /(\.githooks\/|tool\/docs-attest\.sh|tool\/docs-drift\.sh)/) ? 1 : 0; next }
    skip { next }
    /^\+\+\+/ { next }
    /^\+/ { print }
  ')"
  if printf '%s\n' "$added" | grep -qE "$SECRET_RE"; then
    block_secret "Ref ${_lref:-?} · zu pushen bis ${local_sha:0:12}"
  fi
done <<EOF
$REFS
EOF

# ── Riegel 2: Public-Docs für genau diesen Commit attestiert? ────────────────
pushed_any=0
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue          # Branch-Löschung -> egal
  pushed_any=1
  # Annotierte Tags zeigen auf einen Commit -> diesen prüfen, nicht die Tag-SHA.
  commit_sha="$(git rev-parse --verify --quiet "${local_sha}^{commit}" 2>/dev/null || echo "$local_sha")"
  if [ "$commit_sha" != "$attested" ]; then
    block "Zu pushen: ${commit_sha:0:12} · zuletzt attestiert: ${attested:0:12}"
  fi
done <<EOF
$REFS
EOF

# Falls git keine Refs auf stdin lieferte, gegen HEAD prüfen.
if [ "$pushed_any" -eq 0 ]; then
  head="$(git rev-parse HEAD)"
  [ "$head" = "$attested" ] || block "HEAD ${head:0:12} ist nicht attestiert."
fi

# ── Riegel 3: Dogfood-Gate — loam prüft loam ─────────────────────────────────
# Eigenes Tool gegen eigenen Code: unused-public-exports u. a. Toter/ungenutzter
# Public-Code im CLI blockt den Push. `gate --absolute` = rot bei JEDEM Finding,
# kein baseline.json nötig. ~6s (dart run kompiliert die aktuelle Quelle).
# Robust: fehlt dart im Hook-PATH (GUI-Clients), wird das Quality-Net übersprungen
# statt fälschlich zu blockieren — die Sicherheits-/Attestierungs-Riegel oben gelten
# weiter und der dart-test-Lauf fängt es ohnehin.
DART="$(command -v dart || true)"
if [ -z "$DART" ]; then
  echo "pre-push: dart nicht im PATH — loam-Dogfood-Gate übersprungen (Quality-Net)." >&2
else
  echo "loam-Dogfood-Gate: gate --absolute auf packages/loam_cli …" >&2
  if ! ( cd "$ROOT/packages/loam_cli" && "$DART" run bin/loam.dart gate --absolute --project-root . ); then
    cat >&2 <<EOF

╳ Push blockiert — loam-Dogfood-Gate ROT: loam findet Probleme im eigenen Code.
  → Findings oben beheben (toter/ungenutzter Public-Code), dann erneut pushen.
    (kein --no-verify)
EOF
    exit 1
  fi
fi

# ── Soft-Check (ADVISORY, blockt NIE): semantische Doc-Drift vor dem Push ─────
# LLM-Plausibilitätscheck der Public-Docs gegen den Code-Stand — der harte
# docs-attest sieht nur Struktur/Version, nicht Prosa-Veraltung. KEIN Gate
# (Invariante 2: kein LLM im blockierenden Gate; gleiche Logik wie der nicht-
# blockierende Nudge im pre-commit). Läuft NUR wenn der Push Public-Flächen
# berührt, die claude-CLI da ist und nicht via LOAM_SKIP_DRIFT=1 abgeschaltet.
# So fällt Drift HIER auf, nicht erst in CI. Bricht den Push unter keinen
# Umständen ab.
if [ "${LOAM_SKIP_DRIFT:-0}" != "1" ] && command -v claude >/dev/null 2>&1 \
   && [ -x "$ROOT/tool/docs-drift.sh" ]; then
  DRIFT_SURFACE='(^README\.md|^packages/loam_cli/(README\.md|CHANGELOG\.md|pubspec\.yaml|bin/|lib/)|^docs/developer-guide\.md|^web/)'
  touched=0
  while read -r _lref local_sha _rref remote_sha; do
    [ -z "${local_sha:-}" ] && continue
    [ "$local_sha" = "$ZERO" ] && continue
    local_sha="$(git rev-parse --verify --quiet "${local_sha}^{commit}" 2>/dev/null || echo "$local_sha")"
    if [ "${remote_sha:-$ZERO}" = "$ZERO" ]; then
      files="$(git log --name-only --format= "$local_sha" --not --remotes 2>/dev/null || true)"
    else
      files="$(git diff --name-only "${remote_sha}..${local_sha}" 2>/dev/null || true)"
    fi
    printf '%s\n' "$files" | grep -qE "$DRIFT_SURFACE" && touched=1
  done <<EOF
$REFS
EOF
  if [ "$touched" = "1" ]; then
    echo "› docs-drift Soft-Check (advisory, blockt nicht) — Public-Flächen berührt …" >&2
    TIMEOUT="$(command -v timeout || command -v gtimeout || true)"
    report="$(${TIMEOUT:+$TIMEOUT 120} "$ROOT/tool/docs-drift.sh" --llm 2>/dev/null || true)"
    if [ -n "$report" ]; then
      printf '%s\n' "$report" | sed 's/^/  │ /' >&2
      echo "  └─ Hinweis, kein Gate. Voll: tool/docs-drift.sh --llm · Aus: LOAM_SKIP_DRIFT=1" >&2
    else
      echo "  (docs-drift lieferte keinen Report — übersprungen, Push läuft weiter)" >&2
    fi
  fi
fi

echo "Public-Docs-QS: README für ${attested:0:12} attestiert · kein KI-Trailer · loam-Dogfood grün — Push frei."
