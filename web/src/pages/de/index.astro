---
import Layout from '../../layouts/Layout.astro';
import GitHubStars from '../../components/GitHubStars.astro';
import { t } from '../../i18n/ui';

// Build-time fetch — bake a star count into the HTML for JS-free fallback.
// On any failure (network, timeout, API rate-limit) we fall back to null
// and render the neutral CTA without a number. The build must never fail here.
let initialStars: number | null = null;
try {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 3000);
  const res = await fetch('https://api.github.com/repos/silvio-l/loam', {
    signal: controller.signal,
    headers: { 'Accept': 'application/vnd.github+json' },
  });
  clearTimeout(timer);
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === 'number') {
      initialStars = data.stargazers_count;
    }
  }
} catch (_) {
  // Network unavailable, timeout, or API error — neutral CTA rendered below.
}
---

<Layout
  lang="de"
  title="loam.dev — Codebase-Intelligence &amp; Anti-AI-Slop für Dart &amp; Flutter"
  description="loam.dev findet strukturellen Drift und KI-generierten Slop, den dart analyze übersieht — semantisch und über das ganze Projekt. In der CI duldet eine Baseline den Bestand und blockiert nur, was neu dazukommt."
  path="/de/"
>
  <div class="home-main">
    <img class="mark" src="/icon-mark.svg" alt="loam.dev Logo — ein Keimling wächst aus geschichteten Erdschichten">
    <span class="lockup">
      <img class="wm-hero" src="/wordmark.svg" alt="loam.dev">
      <span class="caret" aria-hidden="true"></span>
    </span>
    <p class="tagline">Codebase-Intelligence &amp; <em>Anti-AI-Slop</em> für Dart&nbsp;&amp;&nbsp;Flutter.</p>
    <p class="sub">Findet den strukturellen Drift und den KI-generierten Slop, den <code>dart&nbsp;analyze</code>
       übersieht.</p>
    <div class="cmd">
      <span class="p">$</span><span class="t" id="cmd">dart pub global activate loam</span>
      <button id="copy" aria-label="Installationsbefehl kopieren">kopieren</button>
    </div>
    <nav class="links">
      <a href="https://pub.dev/packages/loam">pub.dev</a>
      <span class="sep"></span>
      <a href="https://github.com/silvio-l/loam">GitHub</a>
      <span class="sep"></span>
      <a href="/de/developer-guide/">Doku</a>
      <span class="sep"></span>
      <a href="mailto:silvio-lindstedt@outlook.com">Kontakt</a>
      <span class="sep"></span>
      <button class="sharelink" id="share" type="button">teilen</button>
    </nav>
    <div class="stars-wrap">
      <GitHubStars
        initialCount={initialStars}
        label={t('de', 'stars.label')}
        ariaLabel={t('de', 'stars.ariaLabel')}
      />
    </div>
  </div>
</Layout>

<style is:inline>
  .home-main{
    display:flex; flex-direction:column; align-items:center;
    justify-content:center; text-align:center;
    padding:2.4rem clamp(1.2rem,5vw,3rem) 3rem;
  }
  .mark{ width:clamp(86px,13vw,128px); height:auto; display:block;
    filter:drop-shadow(0 6px 26px rgba(136,200,64,.18)); animation:rise .9s cubic-bezier(.2,.8,.2,1) both; }
  .lockup{ position:relative; display:inline-block; margin:1.5rem auto 0;
    animation:rise .9s .08s cubic-bezier(.2,.8,.2,1) both; }
  .wm-hero{ width:var(--wm); height:auto; display:block; }
  .caret{ position:absolute; left:100%; bottom:0; display:block;
    width:calc(var(--wm) * .104); height:calc(var(--wm) * .032);
    margin-left:calc(var(--wm) * .015); margin-bottom:calc(var(--wm) * .015);
    background:var(--green); border-radius:2px;
    box-shadow:0 0 16px rgba(136,200,64,.7);
    animation:blink 1.05s steps(1,end) infinite; }

  .tagline{ font-size:clamp(1.15rem,3vw,1.7rem); font-weight:500; line-height:1.35; color:var(--ink);
    max-width:26ch; margin:1.5rem auto 0; animation:rise .9s .16s cubic-bezier(.2,.8,.2,1) both; }
  .tagline em{ font-style:italic; font-weight:400; color:var(--green); }
  .sub{ font-size:clamp(.82rem,1.7vw,.95rem); font-weight:400; line-height:1.65; color:var(--dim);
    max-width:56ch; margin:1.3rem auto 0; animation:rise .9s .24s cubic-bezier(.2,.8,.2,1) both; }
  .sub code{ color:var(--ink); background:rgba(255,255,255,.05); padding:.05em .4em; border-radius:5px; }

  .cmd{ margin:2.2rem auto 0; display:inline-flex; align-items:center; gap:.9rem; font-size:clamp(.82rem,1.8vw,.96rem);
    background:linear-gradient(180deg,var(--panel),#101216); border:1px solid var(--line); border-radius:12px;
    padding:.8rem 1rem .8rem 1.1rem; box-shadow:0 12px 40px rgba(0,0,0,.45);
    animation:rise .9s .32s cubic-bezier(.2,.8,.2,1) both; }
  .cmd .p{ color:var(--green); } .cmd .t{ color:var(--ink); }
  .cmd button{ font:600 .68rem var(--font); letter-spacing:.12em; text-transform:uppercase; color:var(--dim);
    background:transparent; border:1px solid #2b2d33; border-radius:7px; padding:.34rem .6rem; cursor:pointer; transition:.18s; }
  .cmd button:hover,.cmd button.ok{ color:var(--green); border-color:rgba(136,200,64,.5); }

  .links{ margin-top:2.1rem; display:flex; gap:1.4rem; align-items:center; justify-content:center; font-size:.85rem;
    animation:rise .9s .4s cubic-bezier(.2,.8,.2,1) both; }
  .links a{ color:var(--ink); text-decoration:none; border-bottom:1px solid rgba(236,233,225,.22); padding-bottom:2px; transition:.18s; }
  .links a:hover{ color:var(--green); border-color:var(--green); }
  .links .sep{ width:4px; height:4px; border-radius:50%; background:var(--line); }
  .links .sharelink{ font:inherit; color:var(--ink); background:transparent; border:none;
    border-bottom:1px solid rgba(236,233,225,.22); padding:0 0 2px; cursor:pointer; transition:.18s; }
  .links .sharelink:hover,.links .sharelink.ok{ color:var(--green); border-color:var(--green); }

  .stars-wrap{ margin-top:2rem; animation:rise .9s .48s cubic-bezier(.2,.8,.2,1) both; }

  @keyframes blink{ 0%,50%{ opacity:1; } 50.01%,100%{ opacity:0; } }
</style>

<script is:inline>
  const b=document.getElementById('copy');
  b?.addEventListener('click',async()=>{ try{
    await navigator.clipboard.writeText(document.getElementById('cmd').textContent.trim());
    b.textContent='kopiert'; b.classList.add('ok'); setTimeout(()=>{b.textContent='kopieren';b.classList.remove('ok');},1600);
  }catch(e){} });

  const s=document.getElementById('share');
  const shareData={ title:'loam.dev', text:'Codebase-Intelligence & Anti-AI-Slop für Dart & Flutter.', url:'https://getloam.dev/de/' };
  s?.addEventListener('click',async()=>{ try{
    if(navigator.share){ await navigator.share(shareData); return; }
    await navigator.clipboard.writeText(shareData.url);
    s.textContent='Link kopiert'; s.classList.add('ok'); setTimeout(()=>{s.textContent='teilen';s.classList.remove('ok');},1600);
  }catch(e){} });
</script>
