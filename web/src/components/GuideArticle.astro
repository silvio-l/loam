---
/**
 * GuideArticle — rendert den Developer & Tool Guide (docs/developer-guide.md)
 * über den Astro-Content-Layer in das gebrandete Layout. Single-Source: der
 * Inhalt kommt direkt aus docs/, es gibt keine Kopie unter web/. Die Prosa ist
 * bewusst an `.prose-page` (how-it-works / rules) angeglichen, damit alle
 * Inhalts-Seiten einheitlich aussehen.
 */
import { getEntry, render } from 'astro:content';

const entry = await getEntry('guide', 'developer-guide');
if (!entry) {
  throw new Error(
    'GuideArticle: Content-Eintrag "developer-guide" nicht gefunden — ' +
      'erwartet docs/developer-guide.md (siehe web/src/content.config.ts).',
  );
}
const { Content } = await render(entry);
---

<article class="prose-page prose-page--md" style="position:relative;z-index:3;">
  <Content />
</article>
