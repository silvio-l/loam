---
/**
 * GuideArticle — rendert den Developer & Tool Guide (docs/developer-guide.md)
 * über den Astro-Content-Layer in das gebrandete Layout. Single-Source: der
 * Inhalt kommt direkt aus docs/, es gibt keine Kopie unter web/. Die Prosa ist
 * bewusst an `.prose-page` (how-it-works / rules) angeglichen, damit alle
 * Inhalts-Seiten einheitlich aussehen.
 */
import { getEntry, render } from 'astro:content';

const entry = await getEntry('guide', 'developer-guide');
if (!entry) {
  throw new Error(
    'GuideArticle: Content-Eintrag "developer-guide" nicht gefunden — ' +
      'erwartet docs/developer-guide.md (siehe web/src/content.config.ts).',
  );
}
const { Content } = await render(entry);
---

<article class="guide prose-page">
  <Content />
</article>

<style is:inline>
  .guide {
    max-width: 72ch;
    margin: 0 auto;
    padding: 3rem clamp(1.2rem, 5vw, 3rem) 5rem;
    line-height: 1.7;
    position: relative;
    z-index: 3;
  }
  .guide :global(h1) {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 1.4rem;
  }
  .guide :global(h2) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--green);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 2.8rem 0 1rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
  }
  .guide :global(h3) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin: 1.6rem 0 0.3rem;
  }
  .guide :global(p),
  .guide :global(ul),
  .guide :global(ol) {
    color: var(--dim);
    font-size: 0.9rem;
    margin: 0 0 0.8rem;
  }
  .guide :global(ul),
  .guide :global(ol) {
    padding-left: 1.4rem;
  }
  .guide :global(li) {
    margin-bottom: 0.4rem;
  }
  .guide :global(a) {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid rgba(236, 233, 225, 0.3);
    padding-bottom: 1px;
    transition: 0.18s;
  }
  .guide :global(a:hover) {
    color: var(--green);
    border-color: var(--green);
  }
  .guide :global(strong) {
    color: var(--ink);
  }
  .guide :global(code) {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.05em 0.4em;
    border-radius: 5px;
    font-size: 0.88em;
    font-family: var(--font);
  }
  .guide :global(pre) {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    margin: 0 0 1.2rem;
  }
  .guide :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--ink);
  }
  .guide :global(blockquote) {
    border-left: 2px solid var(--green);
    padding: 0.2rem 0 0.2rem 1rem;
    margin: 0 0 1rem;
    color: var(--dim);
    font-size: 0.9rem;
  }
  .guide :global(blockquote p) {
    margin-bottom: 0.4rem;
  }
  .guide :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 2.2rem 0;
  }
  .guide :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.2rem;
    font-size: 0.86rem;
  }
  .guide :global(th),
  .guide :global(td) {
    border: 1px solid var(--line);
    padding: 0.45rem 0.6rem;
    text-align: left;
    color: var(--dim);
  }
  .guide :global(th) {
    color: var(--green);
  }
</style>
